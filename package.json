{
  "name": "the-open-above",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Cinematic hot air balloon wind-drift experience powered by Nexus Engine Realtime Core.",
  "scripts": {
    "start": "vite --host 0.0.0.0",
    "dev": "vite --host 0.0.0.0",
    "check": "node tests/smoke.mjs && node tests/terrain-streaming.mjs && node tests/world-route-protection.mjs && node tests/terrain-overlays.mjs",
    "build": "npm run check && vite build",
    "headless:status": "node .nexus-engine/bin/nexus-editor.mjs --environment ./tools/headless-editor-environment.mjs status --json",
    "headless:inspect": "node .nexus-engine/bin/nexus-editor.mjs --environment ./tools/headless-editor-environment.mjs call project.inspect --json",
    "headless:renderer": "node .nexus-engine/bin/nexus-editor.mjs --environment ./tools/headless-editor-environment.mjs call renderer.validate --json",
    "headless:check": "node .nexus-engine/bin/nexus-editor.mjs --environment ./tools/headless-editor-environment.mjs call project.check --json",
    "headless:build": "node .nexus-engine/bin/nexus-editor.mjs --environment ./tools/headless-editor-environment.mjs call project.build --json"
  },
  "dependencies": {
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "vite": "^6.0.0"
  },
  "devDependencies": {},
  "license": "UNLICENSED"
}
